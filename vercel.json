{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://smartgumastha-backend-production.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "medihost.in" }],
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.medihost.in" }],
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/site.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ]
}
